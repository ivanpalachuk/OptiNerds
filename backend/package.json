{
  "name": "optinerds-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate:local": "wrangler d1 execute optinerds-db --local --file=migrations/0000_initial.sql",
    "db:migrate:remote": "wrangler d1 execute optinerds-db-prod --remote --file=migrations/0000_initial.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.29.5",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.20.18",
    "typescript": "^5.7.3",
    "wrangler": "^3.94.0"
  }
}
